---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FadeIn from "@/components/FadeIn";
---

<BaseLayout title="David Rodriguez — Developer">
  <main class="mx-auto max-w-2xl px-6 py-20">
    <!-- Hero -->
    <FadeIn client:load>
      <section class="mb-20">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
          David Rodriguez
        </h1>
        <p class="mt-4 text-lg text-text-muted">
          Developer building things for the web. Currently focused on browser
          extensions, personal tools, and learning in public.
        </p>
        <div class="mt-6 flex gap-4">
          <a
            href="#contact"
            class="rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition hover:bg-primary-dark"
          >
            Get in touch
          </a>
          <a
            href="#experience"
            class="rounded-lg border border-text-muted/30 px-4 py-2 text-sm font-medium text-text-muted transition hover:text-text hover:border-text"
          >
            View experience
          </a>
        </div>
      </section>
    </FadeIn>

    <!-- Experience Timeline -->
    <FadeIn client:visible delay={0.1}>
      <section id="experience" class="mb-20">
        <h2 class="mb-8 text-2xl font-semibold">Experience</h2>
        <ol class="relative border-l border-text-muted/20 ml-3">
          <!-- Replace these with your real experience entries -->
          <li class="mb-10 ml-6">
            <span class="absolute -left-2 h-4 w-4 rounded-full bg-primary" />
            <time class="mb-1 block text-sm text-text-muted">
              2024 — Present
            </time>
            <h3 class="text-lg font-medium">Your Current Role</h3>
            <p class="text-text-muted">
              Description of what you do, technologies you work with, and key
              accomplishments. Replace this placeholder with your real content.
            </p>
          </li>
          <li class="mb-10 ml-6">
            <span class="absolute -left-2 h-4 w-4 rounded-full bg-primary/60" />
            <time class="mb-1 block text-sm text-text-muted">
              2022 — 2024
            </time>
            <h3 class="text-lg font-medium">Previous Role</h3>
            <p class="text-text-muted">
              Description of your responsibilities and achievements. Replace
              this placeholder with your real content.
            </p>
          </li>
          <li class="ml-6">
            <span class="absolute -left-2 h-4 w-4 rounded-full bg-primary/30" />
            <time class="mb-1 block text-sm text-text-muted">
              2020 — 2022
            </time>
            <h3 class="text-lg font-medium">Earlier Role</h3>
            <p class="text-text-muted">
              Description of your earlier work. Replace this placeholder with
              your real content.
            </p>
          </li>
        </ol>
      </section>
    </FadeIn>

    <!-- Contact -->
    <FadeIn client:visible delay={0.2}>
      <section id="contact" class="mb-20">
        <h2 class="mb-4 text-2xl font-semibold">Get in Touch</h2>
        <p class="text-text-muted mb-6">
          Interested in working together or just want to say hi? Reach out
          through any of the channels below.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="mailto:billing@dmrodriguez.net"
            class="rounded-lg border border-text-muted/30 px-4 py-2 text-sm font-medium text-text-muted transition hover:text-text hover:border-text"
          >
            Email
          </a>
          <a
            href="https://github.com/DaveHQ"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-text-muted/30 px-4 py-2 text-sm font-medium text-text-muted transition hover:text-text hover:border-text"
          >
            GitHub
          </a>
        </div>
      </section>
    </FadeIn>
  </main>
</BaseLayout>
